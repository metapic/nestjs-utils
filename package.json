{
  "name": "@metapic/nestjs-utils",
  "version": "0.0.0-development",
  "description": "Utilities and helpers for Nest.js + TypeORM.",
  "type": "module",
  "exports": "./dist/index.js",
  "files": [
    "dist/**/*"
  ],
  "homepage": "https://github.com/metapic/nestjs-utils",
  "bugs": {
    "url": "https://github.com/metapic/nestjs-utils/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metapic/nestjs-utils.git"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf ./dist",
    "lint": "tsc && eslint --cache",
    "lint:fix": "tsc && eslint --cache --fix",
    "semantic-release": "semantic-release"
  },
  "license": "MIT",
  "author": {
    "name": "Daniel Stockhammer",
    "url": "https://github.com/dstockhammer"
  },
  "engines": {
    "node": ">= 20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nestjs",
    "typeorm"
  ],
  "workspaces": [
    ".",
    "example"
  ],
  "peerDependencies": {
    "@nestjs/common": ">=11",
    "@nestjs/core": ">=11",
    "@nestjs/swagger": ">=11",
    "@nestjs/typeorm": ">=11",
    "change-case": ">=5",
    "class-transformer": ">=0.5.1",
    "class-validator": ">=0.14.3",
    "nestjs-typeorm-paginate": ">=4"
  },
  "devDependencies": {
    "@metapic/eslint-config": "^1.0.10",
    "@metapic/prettier-config": "^1.0.3",
    "@nestjs/common": "^11.1.12",
    "@nestjs/core": "^11.1.12",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/typeorm": "^11.0.0",
    "@types/node": "^25.0.10",
    "change-case": "^5.4.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "jiti": "^2.6.1",
    "nestjs-typeorm-paginate": "^4.1.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.2",
    "typescript": "^5.9.3"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      [
        "@semantic-release/github",
        {
          "assets": [
            "dist/**"
          ]
        }
      ]
    ]
  }
}
